@model T3_Espinoza_Diego.Models.Libro

@{
    ViewData["Title"] = "Eliminar Libro";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<form method="post" asp-action="EliminarPost">
    <input asp-for="Id" hidden />

    <div class="border p-3">
        <div class="form-group row">
            <h2 class="text-danger pl-3">Eliminar Libro</h2>
        </div>

        <p class="text-danger">¿Está seguro de que desea eliminar este libro?</p>

        <div class="container">
            <div class="row mb-3">
                <div class="col-md-6">
                    <label asp-for="Titulo" class="form-label">Título</label>
                    <input asp-for="Titulo" class="form-control" disabled />
                </div>

                <div class="col-md-6">
                    <label asp-for="Autor" class="form-label">Autor</label>
                    <input asp-for="Autor" class="form-control" disabled />
                </div>
            </div>

            <div class="row mb-3">
                <div class="col-md-6">
                    <label asp-for="Tema" class="form-label">Tema</label>
                    <input asp-for="Tema" class="form-control" disabled />
                </div>

                <div class="col-md-6">
                    <label asp-for="Editorial" class="form-label">Editorial</label>
                    <input asp-for="Editorial" class="form-control" disabled />
                </div>
            </div>

            <div class="row mb-3">
                <div class="col-md-4">
                    <label asp-for="AnioPublicacion" class="form-label">Año de Publicación</label>
                    <input asp-for="AnioPublicacion" class="form-control" disabled />
                </div>

                <div class="col-md-4">
                    <label asp-for="Paginas" class="form-label">Páginas</label>
                    <input asp-for="Paginas" class="form-control" disabled />
                </div>

                <div class="col-md-4">
                    <label asp-for="Copias" class="form-label">Copias</label>
                    <input asp-for="Copias" class="form-control" disabled />
                </div>
            </div>

            <div class="row mb-3">
                <div class="col-md-6">
                    <label asp-for="Categoria" class="form-label">Categoría</label>
                    <input asp-for="Categoria" class="form-control" disabled />
                </div>

                <div class="col-md-6">
                    <label asp-for="Material" class="form-label">Material</label>
                    <input asp-for="Material" class="form-control" disabled />
                </div>
            </div>

            <div class="d-grid gap-2 d-md-block">
                <button type="submit" class="btn btn-danger">Eliminar</button>
                <a asp-controller="Libro" asp-action="Index" class="btn btn-success">Regresar</a>
            </div>
        </div>
    </div>
</form>