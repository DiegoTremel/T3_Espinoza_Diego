@{
    ViewData["Title"] = "Libros de Arquitectura de Software";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4">
    <h2 class="text-primary mb-4">Libros de Arquitectura de Software</h2>

    <p>
        En esta sección se muestran libros relacionados con la arquitectura de software,
        patrones arquitectónicos, diseño de sistemas escalables, buenas prácticas y toma
        de decisiones técnicas para construir aplicaciones de calidad.
    </p>

    <div class="row mt-4">

        <div class="col-md-4 mb-4">
            <div class="card h-100 shadow">
                <img src="https://covers.openlibrary.org/b/isbn/9780136886099-L.jpg"
                     class="card-img-top"
                     alt="Software Architecture in Practice"
                     style="height:350px; object-fit:contain; padding:15px;" />

                <div class="card-body">
                    <h5 class="card-title">Software Architecture in Practice</h5>
                    <p class="card-text">
                        Libro orientado al estudio de la arquitectura de software,
                        atributos de calidad, documentación arquitectónica y análisis
                        de decisiones en sistemas complejos.
                    </p>

                    <a href="https://openlibrary.org/isbn/9780136886099"
                       target="_blank"
                       class="btn btn-outline-primary">
                        Ver información
                    </a>
                </div>
            </div>
        </div>

        <div class="col-md-4 mb-4">
            <div class="card h-100 shadow">
                <img src="https://covers.openlibrary.org/b/isbn/9780134494166-L.jpg"
                     class="card-img-top"
                     alt="Clean Architecture"
                     style="height:350px; object-fit:contain; padding:15px;" />

                <div class="card-body">
                    <h5 class="card-title">Clean Architecture</h5>
                    <p class="card-text">
                        Presenta principios para organizar el código en capas,
                        separar responsabilidades y construir sistemas mantenibles,
                        flexibles y fáciles de probar.
                    </p>

                    <a href="https://openlibrary.org/isbn/9780134494166"
                       target="_blank"
                       class="btn btn-outline-primary">
                        Ver información
                    </a>
                </div>
            </div>
        </div>

        <div class="col-md-4 mb-4">
            <div class="card h-100 shadow">
                <img src="https://covers.openlibrary.org/b/isbn/9781491986363-L.jpg"
                     class="card-img-top"
                     alt="Building Evolutionary Architectures"
                     style="height:350px; object-fit:contain; padding:15px;" />

                <div class="card-body">
                    <h5 class="card-title">Building Evolutionary Architectures</h5>
                    <p class="card-text">
                        Explica cómo diseñar arquitecturas capaces de evolucionar
                        con el tiempo, manteniendo la calidad y reduciendo el impacto
                        de los cambios.
                    </p>

                    <a href="https://openlibrary.org/isbn/9781491986363"
                       target="_blank"
                       class="btn btn-outline-primary">
                        Ver información
                    </a>
                </div>
            </div>
        </div>

    </div>

    <h3 class="text-info mt-5">Video relacionado</h3>

    <p>
        Video introductorio sobre arquitectura de software y su importancia en el desarrollo de sistemas.
    </p>

    <div class="ratio ratio-16x9 mt-3 mb-5">
        <iframe src="https://www.youtube.com/embed/MbX0hGRiJm8"
                title="Video de Arquitectura de Software"
                allowfullscreen>
        </iframe>
    </div>
</div>
